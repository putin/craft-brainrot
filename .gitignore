# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env.local
.env*.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# lock files (optional: keep package-lock.json if you want reproducible builds)
# package-lock.json

# sitemap & robots (generated at build time)
/public/sitemap*.xml
/public/robots.txt

# bing verification (generated at build time)
/public/*.txt

# editor
.idea/
.vscode/
*.swp
*.swo